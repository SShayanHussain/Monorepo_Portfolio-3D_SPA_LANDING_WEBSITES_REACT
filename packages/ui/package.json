{
  "name": "@portfolio/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared component library for the 8-site portfolio. Consumed as source — Vite transpiles the TS; there is no separate build step.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@react-three/drei": "^9.109.0",
    "@react-three/fiber": "^8.17.0",
    "framer-motion": "^11.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "three": "^0.160.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.160.0"
  }
}
